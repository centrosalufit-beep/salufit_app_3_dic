rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === HELPERS DE SEGURIDAD ===
    function isAuthenticated() { 
      return request.auth != null; 
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users_app/$(request.auth.uid)).data.get('rol', 'none');
    }

    function isStaff() {
      return isAuthenticated() && getRole() in ['admin', 'administrador', 'profesional'];
    }

    function isAdmin() {
      return isAuthenticated() && getRole() in ['admin', 'administrador'];
    }

    function isOwner(userId) { 
      return isAuthenticated() && request.auth.uid == userId; 
    }

    // === REGLAS DE ACCESO ===
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isOwner(userId) || isStaff();
      allow update: if isStaff() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['rol', 'activo', 'email', 'createdAt']));
      allow list: if isStaff();
    }

    match /users_app/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isOwner(userId) || isStaff();
      allow update: if isStaff() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['rol', 'activo', 'email', 'numHistoria', 'createdAt', 'activatedAt']));
      allow list: if isStaff();
    }

    // Blindaje de datos m�dicos ??
    match /patient_data/{id} { 
      allow read, write: if isStaff(); 
    }

    // Seguridad por defecto para admins
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Reglas para el resto de colecciones operativas...
    match /passes/{id} { allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid); allow create: if isStaff(); allow update: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['tokensRestantes'])); allow delete: if isStaff(); }
    match /exercise_assignments/{id} { allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid); allow write: if isStaff(); }
    match /audit_logs/{id} { allow read: if isStaff(); allow create: if isAuthenticated(); }
    match /appointments/{id} { allow read, list: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid); allow write: if isStaff(); }
    match /bookings/{id} { allow read, delete: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid); allow create: if isStaff() || (isAuthenticated() && request.resource.data.userId == request.auth.uid); }
    match /groupClasses/{id} { allow read: if isAuthenticated(); allow create, delete: if isStaff(); allow update: if isStaff() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aforoActual'])); }
    match /documents/{id} { allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid); allow create: if isStaff(); allow update: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firmado', 'fechaFirma', 'firmaDigital', 'firmaCliente', 'firmaProfesional'])); allow delete: if isStaff(); }
    match /consent_templates/{id} { allow read: if isStaff(); allow write: if isAdmin(); }

    // Chat interno entre staff
    match /chats/{chatId} {
      allow read, write: if isStaff();
      match /messages/{msgId} {
        allow read, write: if isStaff();
      }
    }

    // Configuración de la app (versión mínima, etc.)
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Fichajes
    match /timeClockRecords/{id} { allow read: if isStaff(); allow create: if isStaff(); allow update: if isAdmin(); allow delete: if isAdmin(); }
  }
}
