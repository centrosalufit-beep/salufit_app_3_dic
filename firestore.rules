rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    // HELPERS DE SEGURIDAD
    // ═══════════════════════════════════════════════════════════════
    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users_app/$(request.auth.uid)).data.get('rol', 'none');
    }

    function isStaff() {
      return isAuthenticated() && getRole() in ['admin', 'administrador', 'profesional'];
    }

    function isAdmin() {
      return isAuthenticated() && getRole() in ['admin', 'administrador'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Campos protegidos que el cliente NO puede modificar en su propio perfil
    function userProtectedFields() {
      return ['rol', 'activo', 'email', 'numHistoria', 'createdAt', 'activatedAt',
              'uid', 'id', 'id_legacy', 'isDemoAccount', 'migradoDe', 'fechaMigracion'];
    }

    // ═══════════════════════════════════════════════════════════════
    // USERS_APP — Perfil principal del usuario
    // RGPD: Cada usuario solo lee su propio perfil; staff puede listar.
    // ═══════════════════════════════════════════════════════════════
    match /users_app/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      allow create: if isOwner(userId) || isStaff();
      allow update: if isStaff()
                    || (isOwner(userId)
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(userProtectedFields()));
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // USERS (legado) — Solo lectura para staff, sin escritura
    // ═══════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow write: if false; // Colección legacy, bloqueada para nueva escritura
    }

    // ═══════════════════════════════════════════════════════════════
    // BBDD — Base de datos maestra (solo staff)
    // ═══════════════════════════════════════════════════════════════
    match /bbdd/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /legacy_import/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // DATOS MÉDICOS — Historia clínica por paciente
    // Solo staff puede modificar, paciente solo lee lo suyo
    // ═══════════════════════════════════════════════════════════════
    match /patient_data/{id} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isStaff();
    }

    match /patient_metrics/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isStaff());
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /exercises/{id} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isStaff();
    }

    match /exercise_assignments/{id} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create, delete: if isStaff();
      // El cliente puede actualizar SOLO el campo `feedback` de SU assignment
      // (semáforo de dificultad + pulgares).
      allow update: if isStaff()
                    || (isAuthenticated()
                        && resource.data.userId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['feedback']));
    }

    match /documents/{id} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff()
                    || (isAuthenticated() && resource.data.userId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['firmado', 'fechaFirma', 'firmaDigital', 'firmaCliente', 'firmaProfesional']));
      allow delete: if isStaff();
    }

    match /signed_documents/{id} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /consent_templates/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // BONOS Y ASISTENCIA
    // ═══════════════════════════════════════════════════════════════
    match /passes/{id} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isStaff();
      allow update: if isStaff()
                    || (isAuthenticated() && resource.data.userId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['tokensRestantes']));
      allow delete: if isStaff();
    }

    match /bookings/{id} {
      allow read, delete: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isStaff() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow update: if isStaff();
    }

    match /groupClasses/{id} {
      allow read: if isAuthenticated();
      allow create, delete: if isStaff();
      allow update: if isStaff()
                    || (isAuthenticated()
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['aforoActual']));
    }

    // Asistencia walk-in (consumo QR sin reserva) — solo staff puede crear, admin puede borrar
    match /walk_in_attendance/{id} {
      allow read: if isStaff() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create: if isStaff();
      allow update: if false; // Inmutable una vez creado
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // CITAS
    // ═══════════════════════════════════════════════════════════════
    match /appointments/{id} {
      allow read, list: if isStaff() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isStaff();
    }

    // ═══════════════════════════════════════════════════════════════
    // FICHAJES — Solo staff, cliente nunca
    // ═══════════════════════════════════════════════════════════════
    match /timeClockRecords/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // CHAT INTERNO ENTRE STAFF
    // ═══════════════════════════════════════════════════════════════
    match /chats/{chatId} {
      allow read, write: if isStaff();
      match /messages/{msgId} {
        allow read, write: if isStaff();
      }
    }

    // ═══════════════════════════════════════════════════════════════
    // CONFIGURACIÓN
    // ═══════════════════════════════════════════════════════════════
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /system_config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // CRM
    // ═══════════════════════════════════════════════════════════════
    match /crm_entries/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /crm_leads/{id} {
      allow read, create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /crm_metrics/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // PAGOS Y RENOVACIONES — Solo admin
    // ═══════════════════════════════════════════════════════════════
    match /monthly_payments/{id} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // TAREAS DE STAFF
    // ═══════════════════════════════════════════════════════════════
    match /staff_tasks/{id} {
      allow read: if isStaff();
      // El cliente puede crear tareas de tipo `video_difficulty_red`
      // automáticas desde el reproductor cuando marca rojo, siempre que
      // él mismo sea el `clientId` de la tarea.
      allow create: if isStaff()
                    || (isAuthenticated()
                        && request.resource.data.type == 'video_difficulty_red'
                        && request.resource.data.clientId == request.auth.uid);
      // El cliente puede ACTUALIZAR su propia tarea video_difficulty_red
      // existente solo para incrementar el contador de reportes y
      // refrescar la fecha (deduplicación). No puede cambiar otros campos.
      allow update: if isStaff()
                    || (isAuthenticated()
                        && resource.data.type == 'video_difficulty_red'
                        && resource.data.clientId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['reportCount', 'lastReportAt', 'pushPending']));
      allow delete: if isAdmin();
    }

    // Stats agregados de feedback por ejercicio (counters likes/dislikes
    // y por nivel de dificultad). Lectura: staff (panel admin). Escritura:
    // cualquier autenticado, ya que la app cliente actualiza counters via
    // FieldValue.increment al votar en el reproductor.
    match /exerciseStats/{exerciseId} {
      allow read: if isStaff();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /internal_chats/{id} {
      allow read, write: if isStaff();
    }

    match /internal_tasks/{id} {
      allow read, write: if isStaff();
    }

    // ═══════════════════════════════════════════════════════════════
    // AUDITORÍA — Append-only, solo staff lee, cualquier auth puede añadir
    // ═══════════════════════════════════════════════════════════════
    match /audit_logs/{id} {
      allow read: if isStaff();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Inmutable
    }

    // ═══════════════════════════════════════════════════════════════
    // SOLICITUDES DE OTP (para 2FA en acciones sensibles)
    // ═══════════════════════════════════════════════════════════════
    match /otp_requests/{id} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // RATE LIMITS — Backend only (Cloud Functions usa admin SDK)
    // ═══════════════════════════════════════════════════════════════
    match /rate_limits/{id} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // DENEGACIÓN POR DEFECTO — cualquier colección no listada queda bloqueada
    // ═══════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
