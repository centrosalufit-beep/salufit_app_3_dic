index 4210097..e01287a 100644
--- a/pubspec.yaml
+++ b/pubspec.yaml
@@ -1,94 +1,68 @@
-name: salufit_app
-description: Aplicación de gestión integral para Salufit.
-publish_to: 'none'
-
-# El +2 es vital para que la tienda detecte la actualización.
-version: 1.0.2+6
-
-environment:
-  sdk: '>=3.0.0 <4.0.0'
-
-dependencies:
-  flutter:
-    sdk: flutter
-  
-  # --- IDIOMA Y FORMATOS ---
-  flutter_localizations:
-    sdk: flutter
-  intl: ^0.20.0
-
-  # --- FIREBASE ---
-  firebase_core: ^3.0.0
-  firebase_auth: ^5.0.0
-  cloud_firestore: ^5.0.0
-  firebase_storage: ^12.0.0
-  cloud_functions: ^5.0.0
-  firebase_messaging: ^15.0.0 
-  firebase_app_check: ^0.3.2+10
-
-  # --- CONEXIÓN INTERNET ---
-  http: ^1.2.0
-  url_launcher: ^6.2.0
-
-  # --- SEGURIDAD Y BIOMETRÍA ---
-  local_auth: ^3.0.0
-  flutter_secure_storage: ^9.0.0
-  shared_preferences: ^2.3.0
-
-  # --- HARDWARE Y SENSORES ---
-  permission_handler: ^11.3.0
-  network_info_plus: ^6.1.0
-  device_info_plus: ^11.0.0
-  package_info_plus: ^8.0.0
-  
-  # --- CÓDIGOS QR (NUEVA LIBRERÍA: PLAN B) ---
-  qr_flutter: ^4.1.0
-  qr_code_scanner: ^1.0.1
-
-  # --- ARCHIVOS Y PDF ---
-  file_picker: ^8.0.0
-  pdf: ^3.10.0
-  printing: ^5.13.0
-  path_provider: ^2.1.2
-  excel: ^4.0.6
-
-  # --- MULTIMEDIA ---
-  video_player: ^2.8.0
-  chewie: ^1.8.0
-  image_picker: ^1.2.1
-
-  # --- UI ---
-  cupertino_icons: ^1.0.2
-
-dev_dependencies:
-  flutter_test:
-    sdk: flutter
-  flutter_lints: ^6.0.0
-  
-  # Movidos aquí para no ensuciar la app final
-  very_good_analysis: ^10.0.0
-  change_app_package_name: ^1.5.0
-  
-  # Generador de Iconos
-  flutter_launcher_icons: "^0.13.1"
-
-# === CONFIGURACIÓN DEL ICONO DE LA APP ===
-flutter_launcher_icons:
-  android: "launcher_icon"
-  ios: true
-  image_path: "assets/app_icon.png" 
-  min_sdk_android: 21
-  adaptive_icon_background: "#ffffff"
-  adaptive_icon_foreground: "assets/app_icon.png"
-  windows:
-    generate: true
-    icon_size: 48
-
-flutter:
-  uses-material-design: true
